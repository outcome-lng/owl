---
import { Button } from "./Button";
import SectionLabel from "./SectionLabel.astro";
import Figure from "./Figure.astro";
import { withBase } from "../utils/url";

/**
 * Inner-page hero. Tone tints the kicker tick, the left accent rule and the
 * optional CTA to the door the page belongs to: consultancy (teal),
 * products (terracotta), spine (slate, default). `num` is accepted but
 * ignored (kept for backward-compat with existing callers).
 *
 * Pass `imageBase` (+ `imageAlt`) to render a two-column hero with an
 * eager-loaded brand image on the right.
 *
 * Pass `bgImage` to fill the hero with a full-bleed background image behind a
 * left-stronger paper scrim, keeping the dark hero text readable; otherwise
 * the hero stays text-only on the tone wash.
 */
interface Props {
  kicker: string;
  num?: string;
  title: string;
  lede: string;
  tone?: "spine" | "consult" | "product";
  ctaLabel?: string;
  ctaHref?: string;
  imageBase?: string;
  imageAlt?: string;
  bgImage?: string;
}
const { kicker, title, lede, tone = "spine", ctaLabel, ctaHref, imageBase, imageAlt = "", bgImage } = Astro.props;
const ctaVariant = tone === "consult" ? "consult" : tone === "product" ? "product" : "primary";
const wash = { spine: "bg-paper", consult: "bg-consult-wash/40", product: "bg-product-wash/40" }[tone];
const accent = { spine: "bg-spine", consult: "bg-consult", product: "bg-product" }[tone];
const bg = (n: number) => withBase(`/images/${bgImage}-${n}.webp`);
---
<section class={`${bgImage ? "relative bg-paper" : wash} border-b border-line overflow-hidden`}>
  {bgImage && (
    <>
      <img
        src={bg(1600)}
        srcset={`${bg(1040)} 1040w, ${bg(1600)} 1600w`}
        sizes="100vw"
        alt=""
        aria-hidden="true"
        width="1672"
        height="941"
        class="absolute inset-0 w-full h-full object-cover pointer-events-none select-none"
        loading="eager"
        fetchpriority="high"
      />
      <div class="absolute inset-0 bg-linear-to-r from-paper/92 via-paper/82 to-paper/64" aria-hidden="true"></div>
    </>
  )}
  <div class={`${bgImage ? "relative z-10" : ""} max-w-[1080px] mx-auto px-5 sm:px-6 py-16 md:py-24`}>
    {imageBase ? (
      <div>
        <div class="relative pl-5 md:pl-7 mb-7">
          <span class={`absolute left-0 top-0.5 bottom-0.5 w-[3px] rounded-full ${accent}`} aria-hidden="true"></span>
          <SectionLabel text={kicker} tone={tone} />
        </div>
        <h1 class="sr-only">{title}</h1>
        <p class="sr-only">{lede}</p>
        <Figure base={imageBase} alt={imageAlt} eager={true} sizes="(min-width: 1080px) 1016px, 100vw" />
        {ctaLabel && ctaHref && (
          <div class="mt-9 flex justify-center">
            <Button href={ctaHref} variant={ctaVariant}>{ctaLabel}</Button>
          </div>
        )}
      </div>
    ) : (
      <div class="relative pl-5 md:pl-7 max-w-[60ch]">
        <span class={`absolute left-0 top-1.5 bottom-1.5 w-[3px] rounded-full ${accent}`} aria-hidden="true"></span>
        <SectionLabel text={kicker} tone={tone} class="mb-5" />
        <h1 class="max-w-[18ch]">{title}</h1>
        <p class="mt-5 lede">{lede}</p>
        {ctaLabel && ctaHref && (
          <div class="mt-8">
            <Button href={ctaHref} variant={ctaVariant}>{ctaLabel}</Button>
          </div>
        )}
      </div>
    )}
  </div>
</section>
