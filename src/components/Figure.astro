---
// Responsive, brand-framed content image.
// Expects optimised webp widths in public/images/ named <base>-{1600,1040,640}.webp
// (produced by scripts/optimize-content-images.mjs). All sources are native 16:9.
import { withBase } from "../utils/url";

interface Props {
  base: string; // e.g. "home-hero"
  alt: string;
  eager?: boolean; // above-the-fold hero only
  sizes?: string; // responsive sizes hint
  fill?: boolean; // stretch to parent height (object-cover) instead of native 16:9
  class?: string; // extra classes on the frame
}

const { base, alt, eager = false, sizes = "(min-width: 1024px) 1040px, 100vw", fill = false, class: cls = "" } = Astro.props;
const w = (n: number) => withBase(`/images/${base}-${n}.webp`);
const srcset = `${w(640)} 640w, ${w(1040)} 1040w, ${w(1600)} 1600w`;
---

<div class={`relative rounded-lg overflow-hidden ring-1 ring-line/80 bg-spine shadow-[0_22px_60px_-26px_rgba(6,57,91,0.45)] ${fill ? "h-full min-h-[260px]" : ""} ${cls}`}>
  <img
    src={w(1600)}
    srcset={srcset}
    sizes={sizes}
    alt={alt}
    width="1672"
    height="941"
    loading={eager ? "eager" : "lazy"}
    decoding={eager ? "auto" : "async"}
    fetchpriority={eager ? "high" : undefined}
    class={fill ? "block w-full h-full object-cover" : "block w-full h-auto"}
  />
</div>
