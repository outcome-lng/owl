---
import '../styles/global.css';
import { withBase } from '../utils/url';
import { Navbar } from '../components/Navbar';
import { Footer } from '../components/Footer';

interface Props {
  title: string;
  description?: string;
  ogImage?: string;
  type?: 'website' | 'article';
  noindex?: boolean;
}

const {
  title,
  description = 'AI advisory, bid support and the OWL toolset - for teams competing in public-sector and enterprise procurement.',
  ogImage = '/og-image.png', // 1200×630 owl social card (generated by scripts/gen-brand-assets.mjs)
  type = 'website',
  noindex = false,
} = Astro.props;

const canonicalURL = new URL(Astro.url.pathname, Astro.site);
const ogImageURL = new URL(withBase(ogImage), Astro.site);
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <meta name="description" content={description} />
    {noindex && <meta name="robots" content="noindex, nofollow" />}
    <link rel="canonical" href={canonicalURL} />

    <!-- Open Graph -->
    <meta property="og:type" content={type} />
    <meta property="og:url" content={canonicalURL} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={ogImageURL} />
    <meta property="og:site_name" content="Outcome Works" />
    <meta property="og:locale" content="en_GB" />

    <!-- Twitter / X -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImageURL} />

    <!-- Favicon (owl) -->
    <link rel="icon" type="image/svg+xml" href={withBase("/favicon.svg")} />
    <link rel="icon" href={withBase("/favicon.ico")} sizes="48x48" />
    <link rel="icon" type="image/png" sizes="16x16" href={withBase("/favicon-16.png")} />
    <link rel="icon" type="image/png" sizes="32x32" href={withBase("/favicon-32.png")} />
    <link rel="apple-touch-icon" href={withBase("/apple-touch-icon.png")} />

    <!-- Fonts are self-hosted via @fontsource (imported in global.css) -->

    <!-- JSON-LD: Organization (every page) -->
    <script is:inline type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "Organization",
      "@id": "https://outcomeworks.co.uk/#org",
      "name": "Outcome Works Limited",
      "description": "AI advisory, bid & proposal support, and the OWL software suite for teams competing in public-sector and enterprise procurement.",
      "url": "https://outcomeworks.co.uk",
      "email": "hello@outcomeworks.co.uk",
      "areaServed": "GB",
      "knowsAbout": ["AI advisory", "Bid and proposal support", "Public-sector procurement", "Tender intelligence"]
    })} />

    <slot name="head" />
  </head>
  <body class="min-h-screen flex flex-col bg-background text-foreground">
    <Navbar client:load />
    <main class="flex-1 pt-[68px]">
      <slot />
    </main>
    <Footer />
  </body>
</html>
